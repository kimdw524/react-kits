{
  "name": "@kimdw-rtk/eslint-plugin-vanilla-extract",
  "version": "0.0.2",
  "type": "module",
  "private": false,
  "main": "./index.js",
  "exports": {
    ".": {
      "import": "./index.js",
      "default": "./index.js"
    }
  },
  "files": [
    "index.js",
    "rules",
    "README.md"
  ],
  "peerDependencies": {
    "eslint": "^9.0.0"
  },
  "devDependencies": {
    "eslint": "^9.30.0",
    "typescript-eslint": "^8.35.0"
  },
  "scripts": {
    "build": "node --check index.js && node --check rules/sort-properties.js",
    "test": "node --test tests/*.test.js"
  },
  "publishConfig": {
    "access": "public"
  }
}
